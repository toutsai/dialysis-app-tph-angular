{
  "name": "dialysis-app-standalone",
  "version": "1.0.0",
  "description": "透析系統",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --mode standalone",
    "build": "vite build --mode standalone",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "server:start": "cd server && npm start",
    "server:init": "cd server && npm install && npm run init-db",
    "server:install": "cd server && npm install --omit=dev",
    "server:rebuild": "npx @electron/rebuild -f -w better-sqlite3 -m server",
    "standalone": "npm-run-all --parallel server:start dev",
    "electron:dev": "electron .",
    "electron:build": "npm run build && npm run server:install && npm run server:rebuild && electron-builder",
    "electron:build:win": "npm run build && npm run server:install && npm run server:rebuild && electron-builder --win",
    "dist": "npm run build && npm run server:install && npm run server:rebuild && electron-builder --win"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.19",
    "@fullcalendar/daygrid": "^6.1.19",
    "@fullcalendar/interaction": "^6.1.19",
    "@fullcalendar/list": "^6.1.19",
    "@fullcalendar/vue3": "^6.1.19",
    "@vueup/vue-quill": "^1.2.0",
    "@vueuse/core": "^13.9.0",
    "axios": "^1.11.0",
    "dompurify": "^3.3.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.1",
    "pinia": "^3.0.3",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@eslint/js": "^9.22.0",
    "@faker-js/faker": "^9.9.0",
    "@types/node": "^20.17.10",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/eslint-config-prettier": "^10.2.0",
    "dotenv": "^17.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-updater": "^6.1.7",
    "eslint": "^9.22.0",
    "eslint-plugin-vue": "~10.0.0",
    "globals": "^16.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "3.5.3",
    "typescript": "^5.6.3",
    "vite": "^6.2.4",
    "vite-plugin-vue-devtools": "^7.7.2",
    "vue-tsc": "^2.1.10"
  }
}
